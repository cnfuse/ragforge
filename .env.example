# Copy to `.env` and fill in. All variables are optional — ragforge runs fully
# offline with the default local hashing embedder and no LLM.

# --- Language model (optional; enables Claude-backed answers) ---
# ANTHROPIC_API_KEY=sk-ant-...
RAGFORGE_MODEL=claude-opus-4-8
RAGFORGE_MAX_TOKENS=2048
RAGFORGE_EFFORT=high

# --- Embeddings ---
# Provider: "hashing" (local, default) or "voyage" (needs VOYAGE_API_KEY)
RAGFORGE_EMBEDDING_PROVIDER=hashing
RAGFORGE_EMBEDDING_DIM=512
# VOYAGE_API_KEY=...
RAGFORGE_VOYAGE_MODEL=voyage-3

# --- Chunking ---
RAGFORGE_CHUNK_SIZE=800
RAGFORGE_CHUNK_OVERLAP=120

# --- Retrieval ---
RAGFORGE_TOP_K=5

# --- Service ---
RAGFORGE_LOG_LEVEL=INFO
RAGFORGE_HOST=127.0.0.1
RAGFORGE_PORT=8000
